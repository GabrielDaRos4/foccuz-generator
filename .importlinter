[importlinter]
root_packages =
    src
include_external_packages = True

[importlinter:contract:domain-independence]
name = Domain layer must not import from infrastructure
type = forbidden
source_modules =
    src.context.commissions.domain
    src.context.shared.domain
forbidden_modules =
    src.context.commissions.infrastructure
    src.context.shared.infrastructure
    src.adapters
    gspread
    boto3
    requests
    psycopg2

[importlinter:contract:application-purity]
name = Application layer depends on ports not implementations
type = forbidden
source_modules =
    src.context.commissions.application
forbidden_modules =
    src.context.commissions.infrastructure
    gspread
    boto3
    requests
    psycopg2
